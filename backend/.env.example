# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# Routing engine: 'osrm' (free, no key) or 'graphhopper' (needs key)
ROUTING_ENGINE=osrm

# OSRM (default - uses public demo server, replace with self-hosted for production)
OSRM_URL=https://router.project-osrm.org

# GraphHopper (optional - only needed if ROUTING_ENGINE=graphhopper)
GH_URL=https://graphhopper.com/api/1
GH_API_KEY=your_graphhopper_key_here
